# Database Configuration (Neon example)
# Pooled URL for the app (host contains "-pooler")
DATABASE_URL=postgresql://user:password@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# Direct URL for Prisma migrations (same host without "-pooler")
DIRECT_DATABASE_URL=postgresql://user:password@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# Telegram Configuration
# Get your API credentials from https://my.telegram.org
TELEGRAM_API_ID=your_api_id_here
TELEGRAM_API_HASH=your_api_hash_here
TELEGRAM_SESSION_NAME=session_name
TELEGRAM_WATCHED_CHANNELS=@pcagregator,@channel2
TELEGRAM_SCRAPE_CHANNELS=@pcagregator,@samcomptech,@sami_brand12
SCRAPE_DAYS_BACK=180
SCRAPE_LIMIT_PER_CHANNEL=10000
SCRAPE_DOWNLOAD_IMAGES=false
SCRAPE_REQUIRE_DEAL_SIGNAL=true
# Optional — international format: +251704346312 (not 0704346312)
TELEGRAM_PHONE=+251704346312

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=True

# CORS Configuration
# Use * for development, specific origins for production
CORS_ORIGINS=*

# Application
APP_NAME="PC Deal Aggregator"
APP_VERSION="2.0.0"
